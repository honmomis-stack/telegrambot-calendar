# .env.example
# ចម្លងទៅ .env សម្រាប់ test នៅ local (កុំ commit .env ឡើយ)។
# នៅ production៖ ដាក់តម្លៃទាំងនេះក្នុង Vercel → Project → Settings → Environment Variables។

# ---- Telegram (ពី @BotFather) ----
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
# secret header (បង្កើតដោយ: node scripts/gen-secrets.js)
TELEGRAM_WEBHOOK_SECRET=

# ---- Google OAuth (Google Cloud Console → Credentials → OAuth client ID: Web app) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# ត្រូវត្រូវគ្នាបេះបិទនឹង "Authorized redirect URI" ក្នុង Google Console
GOOGLE_REDIRECT_URI=https://your-app.vercel.app/api/oauth/callback

# ---- Gemini AI ----
GEMINI_API_KEY=

# ---- Supabase (Settings → API) ----
SUPABASE_URL=https://xxxx.supabase.co
# service_role key — SERVER ONLY! កុំ expose ទៅ client ឡើយ
SUPABASE_SERVICE_ROLE_KEY=

# ---- Secrets (បង្កើតដោយ: node scripts/gen-secrets.js) ----
ENCRYPTION_KEY=     # 32 bytes base64 ឬ hex (សម្រាប់ encrypt refresh token)
STATE_SECRET=       # HMAC សម្រាប់ OAuth state
CRON_SECRET=        # ការពារ /api/cron/reminders

# ---- ការកំណត់ default (ស្រេចចិត្ត) ----
DEFAULT_TIMEZONE=Asia/Phnom_Penh
DEFAULT_REMINDER_MINUTES=30
# កែតម្រូវលេខថ្ងៃច្រិតគតិ (0 = momentkh ដើម/ផ្លូវការ; 1 = ត្រូវនឹង App ខ្លះ)
KH_LUNAR_OFFSET_DAYS=0

# ---- Admin / Mini App (Phase 3) ----
# Telegram user id របស់ admin (យកដោយវាយ /whoami ក្នុង bot)
ADMIN_TELEGRAM_ID=
# (ស្រេចចិត្ត) base URL បើ domain ខុសពី redirect uri
# PUBLIC_BASE_URL=https://your-app.vercel.app
